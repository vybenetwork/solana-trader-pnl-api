{
  "name": "solana-wallet-pnl-profit-and-loss-api",
  "version": "1.0.0",
  "description": "Solana wallet PnL demo — wallet search, related wallets, and per-wallet PnL via Vybe API",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx src/server.ts",
    "restart:dev": "bash scripts/restart-dev.sh",
    "dev:tunnel": "TUNNEL=1 tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "build:frontend": "tsc -p tsconfig.frontend.json",
    "prestart": "npm run build:frontend",
    "bench:trades": "tsx scripts/bench-trades.ts"
  },
  "keywords": ["solana", "wallet-pnl", "vybe", "profit-and-loss", "wallets", "api"],
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "1.98.4",
    "axios": "1.7.9",
    "dotenv": "16.4.5",
    "express": "4.21.1"
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/node": "22.10.1",
    "typescript": "5.6.3",
    "tsx": "4.19.2"
  },
  "engines": {
    "node": ">=20"
  }
}
